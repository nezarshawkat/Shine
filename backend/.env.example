# Use DATABASE_MODE="local" for fully local SQLite on the backend server.
# Leave DATABASE_URL empty in local mode. Set it only when using Neon/hybrid mode.
DATABASE_MODE="local"
DATABASE_URL=""
LOCAL_DATABASE_PATH="./data/shine-local.db"
LOCAL_UPLOAD_DIR="./public/uploads"
PUBLIC_BACKEND_URL="http://localhost:5000"
HYBRID_DB_ENABLED="true"
HYBRID_SYNC_INTERVAL_MS="15000"
HYBRID_SYNC_BATCH_SIZE="25"
HYBRID_BOOTSTRAP_ON_START="true"
HYBRID_BOOTSTRAP_POST_LIMIT="100"
HYBRID_REFRESH_MS="60000"

JWT_SECRET="shine-super-secret-key"
GOOGLE_CLIENT_ID=""
ENABLE_REDIS_CACHE="false"
ENABLE_SOCKET_IO="false"

# AI posting is off at boot unless explicitly enabled. It can also be started/stopped in Admin.
AUTO_ACTIVITY_ENABLED="true"
AUTO_ACTIVITY_INTERVAL_MS="4320000"
AUTO_ACTIVITY_POSTS_PER_DAY="20"
AUTO_ACTIVITY_COMMUNITY_POST_RATE="0.25"
AUTO_ACTIVITY_ARTICLE_INTERVAL_MS="302400000"
AUTO_ACTIVITY_ARTICLES_PER_WEEK="4"
ORGANIC_ENGAGEMENT_ENABLED="true"
ORGANIC_ENGAGEMENT_INTERVAL_MS="600000"
ORGANIC_ENGAGEMENT_INITIAL_DELAY_MS="300000"
ORGANIC_ENGAGEMENT_BATCH_LIMIT="30"
# Engagement is separate from Auto Activity.
# Views, likes and shares use seeded accounts without AI. Only small related comments use OpenAI.
# It can be started/stopped from Admin > Engagement, and that admin state persists.
ORGANIC_ENGAGEMENT_COMMENT_AI_ENABLED="true"
ORGANIC_ENGAGEMENT_COMMENT_MAX_PER_POST_PER_RUN="2"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
# Search-backed posts use this model and do not require NEWS_API_KEY.
OPENAI_SEARCH_MODEL="gpt-5-search-api"
