# Use DATABASE_MODE="local" for fully local SQLite on the backend server.
# Leave DATABASE_URL empty in local mode. Set it only when using Neon/hybrid mode.
DATABASE_MODE="local"
DATABASE_URL=""
LOCAL_DATABASE_PATH="./data/shine-local.db"
LOCAL_UPLOAD_DIR="./public/uploads"
PUBLIC_BACKEND_URL="http://localhost:5000"
HYBRID_DB_ENABLED="true"
HYBRID_SYNC_INTERVAL_MS="15000"
HYBRID_SYNC_BATCH_SIZE="25"
HYBRID_BOOTSTRAP_ON_START="true"
HYBRID_BOOTSTRAP_POST_LIMIT="100"
HYBRID_REFRESH_MS="60000"

JWT_SECRET="shine-super-secret-key"
GOOGLE_CLIENT_ID=""
ENABLE_REDIS_CACHE="false"
ENABLE_SOCKET_IO="false"
