{
  "rewrites": [
    {
      "source": "/share/(.*)",
      "destination": "https://api.sshine.org/share/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://api.sshine.org/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://api.sshine.org/uploads/$1"
    },
    {
      "source": "/health",
      "destination": "https://api.sshine.org/health"
    },
    {
      "source": "/health/(.*)",
      "destination": "https://api.sshine.org/health/$1"
    },
    { "source": "/(.*)", "destination": "/" }
  ]
}
